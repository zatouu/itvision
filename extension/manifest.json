{
  "manifest_version": 3,
  "name": "IT Vision - Import 1688/AliExpress",
  "version": "2.0.0",
  "description": "Import produits 1688/AliExpress : images classées, vidéos, variantes, description structurée, smart-import",
  "permissions": [
    "activeTab",
    "storage",
    "cookies",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "*://*.1688.com/*",
    "*://*.aliexpress.com/*",
    "*://*.itvisionplus.sn/*",
    "*://itvisionplus.sn/*",
    "*://*.itvision.sn/*",
    "*://localhost/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.1688.com/*",
        "*://*.aliexpress.com/item/*",
        "*://*.aliexpress.com/i/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
