# --- Base de données (OBLIGATOIRE) ---
# URI de connexion à MongoDB. 
# En local Docker : mongodb://admin:AdminPassword123@localhost:27017/itvision?authSource=admin
# En local sans Docker ni auth : mongodb://localhost:27017/itvision
MONGODB_URI=mongodb://localhost:27017/itvision

# --- Sécurité & Authentification (OBLIGATOIRE) ---
# Secret utilisé pour signer les tokens de connexion. Mettez une longue chaîne aléatoire.
JWT_SECRET=mettez-ici-une-chaine-longue-et-aleatoire-pour-securiser-les-sessions

# --- URLs de l'application (OBLIGATOIRE POUR LES EMAILS) ---
# L'URL racine de votre site. Utilisé pour générer les liens dans les emails.
# En local : http://localhost:3000
# En production : https://votre-domaine.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Configuration SMTP (POUR ENVOI EMAILS) ---
# Si ces variables ne sont pas définies, les emails seront seulement affichés dans la console.
# Exemple pour Gmail :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-mot-de-passe-application (Attention: pas votre mot de passe Gmail habituel, créez un mot de passe d'application)

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@example.com
SMTP_PASS=secret-password

# --- Uploads ---
# Dossier où seront stockés les fichiers uploadés (images, documents)
UPLOAD_DIR=./public/uploads

# --- PayDunya (Passerelle de Paiement) ---
# Clés API PayDunya pour activer le paiement par carte bancaire (Visa/MC),
# Wave, Orange Money et Free Money via la passerelle intégrée.
# Créez un compte sur https://paydunya.com et récupérez vos clés.
# Si ces 3 variables sont définies, la passerelle s'active automatiquement.
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
# Mode : 'test' pour le sandbox, 'live' pour la production
PAYDUNYA_MODE=test
# Nom affiché sur la page de paiement PayDunya
PAYDUNYA_STORE_NAME=IT Vision Plus

# --- Numéros marchands Mobile Money (optionnel) ---
# Surcharge les valeurs configurées dans l'admin
# WAVE_MERCHANT_PHONE=+221770000000
# ORANGE_MERCHANT_PHONE=+221770000000
